# OpenClaw gateway shared-secret token. Generate a fresh one with:
#   openssl rand -hex 32
# Use this when logging into the Control UI at https://claw.mooibroek.dev/
OPENCLAW_GATEWAY_TOKEN=replace-me-with-openssl-rand-hex-32

# Pinned image. Override to a versioned tag (e.g. 2026.2.26) once stable.
OPENCLAW_IMAGE=ghcr.io/openclaw/openclaw:latest

# Persistence — host paths, relative to this compose file.
# Must be owned by uid:gid 1000:1000 on the host (the `node` user inside the image).
OPENCLAW_CONFIG_DIR=./data/config
OPENCLAW_WORKSPACE_DIR=./data/workspace
OPENCLAW_AUTH_PROFILE_SECRET_DIR=./data/secrets

# Behavior
OPENCLAW_SANDBOX=1
OPENCLAW_DOCKER_SOCKET=/var/run/docker.sock
OPENCLAW_GATEWAY_BIND=lan
OPENCLAW_DISABLE_BONJOUR=1
OPENCLAW_SKIP_ONBOARDING=1

# Existing external Docker network used by Nginx Proxy Manager on shady.
# Find with: docker network ls   (e.g. nginxproxymanager_default)
PROXY_NETWORK=

TZ=Europe/Amsterdam
